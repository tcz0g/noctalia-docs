---
import config from 'virtual:starlight/user-config';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import { isV5Path } from '../lib/versioning';

const pathname = Astro.url.pathname;
const isV5 = isV5Path(pathname);
const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const faqHref = /^\/v5(?:\/|$)/.test(pathname)
  ? '/v5/getting-started/faq/'
  : '/v4/getting-started/faq/';
---

<div class="header-inner">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>
  <div class="header-search sl-flex print:hidden">
    {shouldRenderSearch && <Search />}
    <a href={faqHref} class="faq-button">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
        <path d="M12 17h.01"></path>
      </svg>
      <span>FAQ</span>
    </a>
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    <div class="sl-flex social-icons">
      <SocialIcons />
    </div>
    <ThemeSelect />
    <LanguageSelect />
  </div>
</div>

<div class:list={['version-alert-banner', isV5 ? 'is-beta' : 'is-stable']} role="alert">
  {isV5 ? (
    <>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
        <line x1="12" y1="9" x2="12" y2="13"></line>
        <line x1="12" y1="17" x2="12.01" y2="17"></line>
      </svg>
      <span>
        You are viewing the <strong>v5 (beta)</strong> docs. <a href="/v4/">Looking for v4 (Quickshell)? →</a>
      </span>
    </>
  ) : (
    <span>
      You are viewing the <strong>v4 (Quickshell)</strong> docs. <a href="/v5/">Check out v5 (beta) →</a>
    </span>
  )}
</div>

<script>
  function updateFaqHref() {
    const faqButton = document.querySelector<HTMLAnchorElement>('.faq-button');
    if (!faqButton) return;
    faqButton.href = /^\/v5(?:\/|$)/.test(window.location.pathname)
      ? '/v5/getting-started/faq/'
      : '/v4/getting-started/faq/';
  }

  function positionBanner() {
    const banner = document.querySelector('.version-alert-banner');
    const header = document.querySelector('.header');
    if (banner && header) {
      header.after(banner);
    }
  }

  function updateBannerVersion() {
    const banner = document.querySelector('.version-alert-banner');
    if (!banner) return;
    const isV5 = /^\/v5(?:\/|$)/.test(window.location.pathname);
    banner.classList.toggle('is-beta', isV5);
    banner.classList.toggle('is-stable', !isV5);

    if (isV5) {
      banner.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
          <line x1="12" y1="9" x2="12" y2="13"></line>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
        <span>
          You are viewing the <strong>v5 (beta)</strong> docs. <a href="/v4/">Looking for v4 (Quickshell)? →</a>
        </span>`;
    } else {
      banner.innerHTML = `
        <span>
          You are viewing the <strong>v4 (Quickshell)</strong> docs. <a href="/v5/">Check out v5 (beta) →</a>
        </span>`;
    }
  }

  updateFaqHref();
  positionBanner();
  document.addEventListener('astro:page-load', () => {
    updateFaqHref();
    positionBanner();
    updateBannerVersion();
  });
</script>

<style>
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sl-nav-gap);
    width: 100%;
    height: 100%;
  }

  .title-wrapper {
    min-width: 0;
    margin: -0.25rem;
    padding: 0.25rem;
    overflow: clip;
  }

  .header-search {
    min-width: 0;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .right-group,
  .social-icons {
    align-items: center;
    gap: 1rem;
  }

  .social-icons::after {
    content: '';
    height: 2rem;
    border-inline-end: 1px solid var(--sl-color-gray-5);
  }

  @media (min-width: 50rem) {
    .header-inner {
      display: grid;
      grid-template-columns: var(--sl-sidebar-width) minmax(0, 1fr) var(--sl-sidebar-width);
      gap: 0;
    }

    .header-search {
      justify-content: flex-start;
      padding-inline: var(--sl-content-pad-x);
    }

    .right-group {
      justify-content: flex-end;
    }
  }

  .faq-button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sl-color-bg);
    background-color: var(--sl-color-accent);
    border: 1px solid var(--sl-color-accent);
    border-radius: var(--sl-border-radius, 0.5rem);
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .faq-button:hover {
    background-color: transparent;
    color: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
  }

  .faq-button svg {
    flex-shrink: 0;
  }

  @media (max-width: 50rem) {
    .faq-button span {
      display: none;
    }
    .faq-button {
      padding: 0.4rem;
    }
  }
</style>

<style is:global>
  .version-alert-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 0.5rem 1.5rem;
    font-size: var(--sl-text-sm);
    font-weight: 500;
    text-align: center;
    line-height: 1.4;
    border-bottom: 2px solid;
    position: fixed;
    top: var(--sl-nav-height);
    left: 0;
    right: 0;
    z-index: var(--sl-z-index-navbar);
  }

  .version-alert-banner.is-beta {
    color: color-mix(in srgb, var(--sl-color-orange) 90%, black);
    background-color: color-mix(in srgb, var(--sl-color-orange) 12%, var(--sl-color-bg));
    border-bottom-color: color-mix(in srgb, var(--sl-color-orange) 40%, transparent);
  }

  [data-theme='dark'] .version-alert-banner.is-beta {
    color: color-mix(in srgb, var(--sl-color-orange) 90%, white);
  }

  .version-alert-banner.is-beta svg {
    flex-shrink: 0;
    color: var(--sl-color-orange);
  }

  .version-alert-banner.is-beta strong {
    color: var(--sl-color-orange);
  }

  .version-alert-banner.is-beta a {
    color: var(--sl-color-orange);
  }

  .version-alert-banner.is-beta a:hover {
    text-decoration-thickness: 2px;
  }

  .version-alert-banner.is-stable {
    color: var(--sl-color-text);
    background-color: color-mix(in srgb, var(--sl-color-accent) 8%, var(--sl-color-bg));
    border-bottom-color: color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
  }

  .version-alert-banner.is-stable strong {
    color: var(--sl-color-text-accent, var(--sl-color-accent));
  }

  .version-alert-banner.is-stable a {
    color: var(--sl-color-text-accent, var(--sl-color-accent));
  }

  .version-alert-banner a {
    margin-inline-start: 0.4rem;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 0.15em;
    white-space: nowrap;
  }

  .version-alert-banner a:hover {
    text-decoration-thickness: 2px;
  }
</style>
